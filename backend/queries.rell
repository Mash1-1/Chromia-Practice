query get_all_tasks(account_id: byte_array) {
    val account = accounts.account @ { .id == account_id };
    val all_tasks = task @* { .account == account } ( 
        id = .rowid,
        .content,
        .created_at
    );
    return all_tasks;
}

query get_latest_task(account_id: byte_array) {
    val account = accounts.account @ { .id == account_id };
    return task @ { .account == account } ( @sort_desc .rowid, id = .rowid, .content, .created_at ) limit 1;
}
